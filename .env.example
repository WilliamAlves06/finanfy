# ── Banco (Supabase) ─────────────────────────────────────────
# pooler (runtime) e conexão direta (migrations) — ver docs/04
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finanfy?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/finanfy?schema=public"

# ── Redis (Upstash em prod, docker local em dev) ─────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET="troque-este-segredo"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="30"

# ── IA (free tiers — ver docs/00 e docs/07) ──────────────────
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
GROQ_API_KEY=""

# ── Canais ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# ── Observabilidade ──────────────────────────────────────────
SENTRY_DSN=""

# ── App ──────────────────────────────────────────────────────
API_PORT="3001"
WEB_ORIGIN="http://localhost:3000"
TZ="America/Sao_Paulo"
